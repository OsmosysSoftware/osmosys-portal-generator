{
  "name": "test-crud-portal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:prod": "ng build --configuration production",
    "lint": "eslint . --max-warnings=0 --ignore-pattern '.angular/**'",
    "lint:fix": "eslint . --fix --ignore-pattern '.angular/**'",
    "prettier-format": "prettier --write \"**/*.{js,ts,html,scss,json}\"",
    "lint-fix-format": "npm run prettier-format && npm run lint:fix && npm run prettier-format",
    "generate:api": "openapi-typescript http://localhost:3000/api/docs-json -o src/app/core/types/api.types.ts",
    "i18n:extract": "ng extract-i18n --output-path src/locale",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "openapi-fetch": "^0.17.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8"
  },
  "description": "Angular portal",
  "lint-staged": {
    "*.ts": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.{js,scss,json}": [
      "prettier --write"
    ]
  }
}
