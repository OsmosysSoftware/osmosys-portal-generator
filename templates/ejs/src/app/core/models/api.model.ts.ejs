// API Type Aliases
//
// Create clean type aliases from auto-generated OpenAPI types.
// Run `npm run generate:api` to regenerate types from the backend Swagger spec.
//
// Example:
//   import { components } from '../types/api.types';
//   export type Application = components['schemas']['ApplicationResponseDto'];
//
// Type Override Pattern (for backend serialization bugs):
//   export type Notification = Omit<
//     components['schemas']['NotificationResponseDto'],
//     'broken_field'
//   > & { broken_field?: number | null; };
